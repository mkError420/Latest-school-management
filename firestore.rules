rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email.matches('.*@gmail\\.com$'));
    }

    function isAuthenticated() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {};
    }

    function hasRole(role) {
      // Safely check for role using get() with a fallback to avoid errors if the field/doc is missing
      // Make it case-insensitive to match the frontend logic
      let data = getUserData();
      let userRole = data.get('role', 'none');
      return isSignedIn() && (userRole == role || userRole.lower() == role.lower());
    }

    function isStaff() {
      let data = getUserData();
      let userRole = data.get('role', 'none').lower();
      return isSignedIn() && !(userRole in ['student', 'parent', 'none']);
    }

    function isSystemAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "mk.rabbani.cse@gmail.com" || 
        request.auth.token.email == "jakir995627@gmail.com" || 
        request.auth.token.email == "akondsourov786@gmail.com"
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "mk.rabbani.cse@gmail.com";
    }

    function isSuperAdminEmail(email) {
      return email == "mk.rabbani.cse@gmail.com";
    }

    function isAdmin() {
      // System admins always have admin rights, otherwise check stored role
      return isSystemAdmin() || (isSignedIn() && hasRole('admin'));
    }

    function getRoleId() {
      let data = getUserData();
      return data.get('roleId', data.get('role', 'none').lower());
    }

    function isApproved() {
      return isSystemAdmin() || (isSignedIn() && (
        getUserData().get('approved', false) == true || 
        getUserData().get('role', 'none').lower() == 'admin'
      ));
    }

    function hasPermission(module, level) {
      return isApproved() && (isAdmin() || (
        level == 'view' ? 
          (exists(/databases/$(database)/documents/roles/$(getRoleId())) && 
           get(/databases/$(database)/documents/roles/$(getRoleId())).data.permissions.get(module, 'none') in ['view', 'full']) :
          (exists(/databases/$(database)/documents/roles/$(getRoleId())) && 
           get(/databases/$(database)/documents/roles/$(getRoleId())).data.permissions.get(module, 'none') == 'full')
      ));
    }

    function isTeacher() {
      return hasRole('teacher') || hasPermission('students', 'view') || isStaff();
    }

    function isParent() {
      return hasRole('parent');
    }

    function isStudent() {
      return hasRole('student');
    }

    // Domain Validators
    function isValidAttendance(data) {
      return data.keys().hasAll(['studentId', 'classId', 'date', 'status', 'createdAt']) &&
             data.studentId is string && data.studentId.size() > 0 &&
             data.classId is string && data.classId.size() > 0 &&
             data.date is string && data.date.size() > 0 &&
             data.status in ['present', 'absent', 'late'] &&
             data.createdAt is string;
    }
    function isValidUser(data) {
      // Basic type validation for common fields
      return (!data.keys().contains('uid') || data.uid is string) &&
             (!data.keys().contains('email') || data.email is string) &&
             (!data.keys().contains('role') || data.role is string) &&
             (!data.keys().contains('approved') || data.approved is bool);
    }

    function isValidSystemConfig(data) {
      // Allow any updates to system config as long as it's from an admin
      return true;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'rollNumber', 'classId', 'guardianPhone', 'admissionDate', 'studentId', 'guardianName', 'guardianRelation']) &&
             data.name is string && data.name.size() > 0 &&
             data.rollNumber is string && data.rollNumber.size() > 0 &&
             data.admissionDate is string && data.admissionDate.size() > 0 &&
             data.studentId is string && data.studentId.size() > 0 &&
             data.guardianName is string && data.guardianName.size() > 0 &&
             data.guardianRelation is string && data.guardianRelation.size() > 0 &&
             (!data.keys().contains('imageUrl') || data.imageUrl is string) &&
             (!data.keys().contains('bloodGroup') || data.bloodGroup in ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"]);
    }

    function isValidExam(data) {
      return data.keys().hasAll(['subject', 'classId', 'date', 'time', 'type', 'status', 'totalMarks']) &&
             data.totalMarks is number && data.totalMarks > 0;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['studentId', 'examId', 'marksObtained', 'grade']) &&
             data.marksObtained is number;
    }

    function isValidStaff(data) {
      return data.keys().hasAll(['staffId', 'name', 'role', 'salary', 'status']) &&
             data.staffId is string && data.staffId.size() > 0 &&
             data.salary is number &&
             data.status in ['active', 'inactive'];
    }

    function isValidPayroll(data) {
      return data.keys().hasAll(['staffId', 'month', 'netSalary', 'status']) &&
             data.netSalary is number &&
             data.status in ['paid', 'pending'];
    }

    function isValidStaffAttendance(data) {
      return data.keys().hasAll(['staffId', 'date', 'status']) &&
             data.staffId is string && data.staffId.size() > 0 &&
             data.date is string && data.date.size() > 0 &&
             data.status in ['present', 'absent', 'late'];
    }

    function isValidRole(data) {
      return data.keys().hasAll(['name', 'permissions']) &&
             data.name is string && data.name.size() > 0;
    }

    function isValidRoutine(data) {
      return data.keys().hasAll(['day', 'className', 'subject', 'startTime', 'endTime']) &&
             data.day in ['Saturday', 'Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'] &&
             data.className is string && data.className.size() > 0 &&
             data.subject is string && data.subject.size() > 0 &&
             data.startTime is string && data.startTime.size() > 0 &&
             data.endTime is string && data.endTime.size() > 0;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidSubject(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!data.keys().contains('code') || (data.code is string && data.code.size() <= 50));
    }

    function isValidNotice(data) {
      return data.keys().hasAll(['title', 'content']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000;
    }

    function isValidGalleryItem(data) {
      return data.keys().hasAll(['url', 'title', 'category']) &&
             data.url is string && data.url.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             data.category in ['campus', 'events', 'academic', 'sports'];
    }

    function isValidCommitteeMember(data) {
      return data.keys().hasAll(['name', 'title']) &&
             data.name is string && data.name.size() > 0 &&
             data.title is string && data.title.size() > 0;
    }

    function isValidDownloadItem(data) {
      return data.keys().hasAll(['name', 'url', 'category']) &&
             data.name is string && data.name.size() > 0 &&
             data.url is string && data.url.size() > 0 &&
             data.category in ['academic', 'admission', 'routine', 'syllabus', 'other'];
    }

    function isValidImportantLink(data) {
      return data.keys().hasAll(['name', 'url', 'order']) &&
             data.name is string && data.name.size() > 0 &&
             data.url is string && data.url.size() > 0 &&
             data.order is number;
    }

    function isValidPublicStaff(data) {
      return data.keys().hasAll(['name', 'role', 'category', 'order']) &&
             data.name is string && data.name.size() > 0 &&
             data.role is string && data.role.size() > 0 &&
             data.category in ['administration', 'teacher', 'other'] &&
             data.order is number;
    }

    function isValidPublicExamResult(data) {
      return data.keys().hasAll(['studentRoll', 'studentName', 'examName', 'grade', 'percentage']) &&
             data.studentRoll is string && data.studentRoll.size() > 0 &&
             data.studentName is string && data.studentName.size() > 0 &&
             data.examName is string && data.examName.size() > 0 &&
             data.grade is string &&
             data.percentage is number;
    }

    // Rules
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(uid) || isSuperAdmin());
      allow update: if isSignedIn() && (
        // Regular access check
        (isOwner(uid) || isSuperAdmin()) && 
        // Protection: Non-SuperAdmins cannot modify the Super Admin's critical fields
        (!isSuperAdminEmail(resource.data.get('email', '')) || isSuperAdmin()) &&
        // Protection: Super Admin must remain approved and remain an admin
        (!isSuperAdminEmail(request.resource.data.get('email', '')) || (
          request.resource.data.get('approved', false) == true && 
          request.resource.data.get('role', 'none').lower() == 'admin'
        ))
      );
      allow delete: if isSuperAdmin();
    }

    match /config/system {
      allow read: if true;
      allow create, update: if isSuperAdmin() && isValidSystemConfig(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /config/{document=**} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow create, update: if isSuperAdmin() && isValidRole(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create, update: if hasPermission('students', 'full') && isValidStudent(request.resource.data);
      allow delete: if hasPermission('students', 'full');
    }

    match /classes/{classId} {
      allow read: if true;
      allow create, update, delete: if hasPermission('students', 'full');
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create, update: if hasPermission('attendance', 'full') && isValidAttendance(request.resource.data);
      allow delete: if hasPermission('attendance', 'full');
    }

    match /exams/{examId} {
      allow read: if true;
      allow create, update: if hasPermission('exams', 'full') && isValidExam(request.resource.data);
      allow delete: if hasPermission('exams', 'full');
    }

    match /results/{resultId} {
      allow read: if isSignedIn();
      allow create, update: if hasPermission('exams', 'full') && isValidResult(request.resource.data);
      allow delete: if hasPermission('exams', 'full');
    }

    match /routine/{routineId} {
      allow read: if isSignedIn();
      allow create, update: if hasPermission('routine', 'full') && isValidRoutine(request.resource.data);
      allow delete: if hasPermission('routine', 'full');
    }

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow create, update: if hasPermission('students', 'full') && isValidSubject(request.resource.data);
      allow delete: if hasPermission('students', 'full');
    }

    match /library_books/{bookId} {
      allow read: if isSignedIn();
      allow create, update, delete: if hasPermission('library', 'full');
    }

    match /library_issues/{issueId} {
      allow read: if isSignedIn();
      allow create, update, delete: if hasPermission('library', 'full');
    }

    match /fees/{feeId} {
      allow read: if isSignedIn();
      allow create, update: if hasPermission('fees', 'full');
      allow delete: if hasPermission('fees', 'full');
    }

    match /staff/{staffId} {
      allow read: if isSignedIn();
      allow create, update: if hasPermission('staff', 'full') && isValidStaff(request.resource.data);
      allow delete: if hasPermission('staff', 'full');
    }

    match /staff_attendance/{id} {
      allow read: if isSignedIn();
      allow create, update: if hasPermission('staff', 'full') && isValidStaffAttendance(request.resource.data);
      allow delete: if hasPermission('staff', 'full');
    }

    match /payroll/{payrollId} {
      allow read: if isSignedIn();
      allow create, update: if hasPermission('payroll', 'full') && isValidPayroll(request.resource.data);
      allow delete: if hasPermission('payroll', 'full');
    }

    match /notifications/{id} {
      allow read: if isOwner(resource.data.recipientId);
      allow create: if isAdmin() || isTeacher();
      allow update: if isOwner(resource.data.recipientId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    match /notices/{id} {
      allow read: if true;
      allow create, update: if isStaff() && isValidNotice(request.resource.data);
      allow delete: if isStaff();
    }

    match /gallery/{id} {
      allow read: if true;
      allow create, update: if isStaff() && isValidGalleryItem(request.resource.data);
      allow delete: if isStaff();
    }

    match /committee/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCommitteeMember(request.resource.data);
      allow delete: if isAdmin();
    }

    match /downloads/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidDownloadItem(request.resource.data);
      allow delete: if isAdmin();
    }

    match /important_links/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidImportantLink(request.resource.data);
      allow delete: if isAdmin();
    }

    match /public_staff/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPublicStaff(request.resource.data);
      allow delete: if isAdmin();
    }

    match /exam_results/{id} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPublicExamResult(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
