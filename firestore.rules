rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email.matches('.*@gmail\\.com$'));
    }

    function isAuthenticated() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      // Use get() to fetch the user document. If it doesn't exist, this will return null.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      // Safely check for role using get() with a fallback to avoid errors if the field/doc is missing
      return isSignedIn() && getUserData().get('role', 'none') == role;
    }

    function isAdmin() {
      // Put the email check first for immediate admin access regardless of DB state
      return isSignedIn() && (
        request.auth.token.email == "mk.rabbani.cse@gmail.com" || 
        request.auth.token.email == "jakir995627@gmail.com" || 
        hasRole('admin')
      );
    }

    function isTeacher() {
      return hasRole('teacher');
    }

    function isParent() {
      return hasRole('parent');
    }

    function isStudent() {
      return hasRole('student');
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.email is string &&
             data.role is string && data.role.size() > 0;
    }

    function isValidSystemConfig(data) {
      return data.keys().hasAll(['schoolName', 'academicYear']) &&
             data.schoolName is string && data.schoolName.size() > 0 &&
             data.academicYear is string && data.academicYear.size() > 0 &&
             (data.get('address', '') is string) &&
             (data.get('phone', '') is string) &&
             (data.get('email', '') is string) &&
             (data.get('website', '') is string) &&
             (data.get('schoolLogoUrl', '') is string);
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'rollNumber', 'classId', 'guardianPhone', 'admissionDate', 'studentId', 'guardianName', 'guardianRelation']) &&
             data.name is string && data.name.size() > 0 &&
             data.rollNumber is string && data.rollNumber.size() > 0 &&
             data.admissionDate is string && data.admissionDate.size() > 0 &&
             data.studentId is string && data.studentId.size() > 0 &&
             data.guardianName is string && data.guardianName.size() > 0 &&
             data.guardianRelation is string && data.guardianRelation.size() > 0 &&
             (!data.keys().contains('imageUrl') || data.imageUrl is string) &&
             (!data.keys().contains('bloodGroup') || data.bloodGroup in ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"]);
    }

    function isValidExam(data) {
      return data.keys().hasAll(['subject', 'classId', 'date', 'time', 'type', 'status', 'totalMarks']) &&
             data.totalMarks is number && data.totalMarks > 0;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['studentId', 'examId', 'marksObtained', 'grade']) &&
             data.marksObtained is number;
    }

    function isValidStaff(data) {
      return data.keys().hasAll(['staffId', 'name', 'role', 'salary', 'status']) &&
             data.staffId is string && data.staffId.size() > 0 &&
             data.salary is number &&
             data.status in ['active', 'inactive'];
    }

    function isValidPayroll(data) {
      return data.keys().hasAll(['staffId', 'month', 'netSalary', 'status']) &&
             data.netSalary is number &&
             data.status in ['paid', 'pending'];
    }

    function isValidStaffAttendance(data) {
      return data.keys().hasAll(['staffId', 'date', 'status']) &&
             data.staffId is string && data.staffId.size() > 0 &&
             data.date is string && data.date.size() > 0 &&
             data.status in ['present', 'absent', 'late'];
    }

    function isValidRole(data) {
      return data.keys().hasAll(['name', 'permissions']) &&
             data.name is string && data.name.size() > 0;
    }

    function isValidRoutine(data) {
      return data.keys().hasAll(['day', 'className', 'subject', 'startTime', 'endTime']) &&
             data.day in ['Saturday', 'Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'] &&
             data.className is string && data.className.size() > 0 &&
             data.subject is string && data.subject.size() > 0 &&
             data.startTime is string && data.startTime.size() > 0 &&
             data.endTime is string && data.endTime.size() > 0;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidSubject(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!data.keys().contains('code') || (data.code is string && data.code.size() <= 50));
    }

    // Rules
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data) && (request.resource.data.role != 'admin' || isAdmin());
      allow update: if isSignedIn() && (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /config/system {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSystemConfig(request.resource.data);
      allow delete: if isAdmin();
    }

    match /config/{document=**} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidRole(request.resource.data);
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create, update: if (isAdmin() || isTeacher()) && isValidStudent(request.resource.data);
      allow delete: if isAdmin() || isTeacher();
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /exams/{examId} {
      allow read: if isSignedIn();
      allow create, update: if (isAdmin() || isTeacher()) && isValidExam(request.resource.data);
      allow delete: if isAdmin() || isTeacher();
    }

    match /results/{resultId} {
      allow read: if isSignedIn();
      allow create, update: if (isAdmin() || isTeacher()) && isValidResult(request.resource.data);
      allow delete: if isAdmin() || isTeacher();
    }

    match /routine/{routineId} {
      allow read: if isSignedIn();
      allow create, update: if (isAdmin() || isTeacher()) && isValidRoutine(request.resource.data);
      allow delete: if isAdmin() || isTeacher();
    }

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow create, update: if (isAdmin() || isTeacher()) && isValidSubject(request.resource.data);
      allow delete: if isAdmin() || isTeacher();
    }

    match /library_books/{bookId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /library_issues/{issueId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /fees/{feeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidStaff(request.resource.data);
      allow delete: if isAdmin();
    }

    match /staff_attendance/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidStaffAttendance(request.resource.data);
      allow delete: if isAdmin();
    }

    match /payroll/{payrollId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidPayroll(request.resource.data);
      allow delete: if isAdmin();
    }

    match /notifications/{id} {
      allow read: if isOwner(resource.data.recipientId);
      allow create: if isAdmin() || isTeacher();
      allow update: if isOwner(resource.data.recipientId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }
  }
}
