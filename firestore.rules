rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, role (admin, teacher, parent, student), createdAt
    //
    // Collection: students
    // Fields: name, rollNumber, classId, guardianPhone, status, etc.
    //
    // Collection: attendance
    // Fields: studentId, classId, date, status, markedBy
    //
    // Collection: fees
    // Fields: studentId, amount, type, status, date
    //
    // Collection: exams
    // Fields: subject, classId, date, time, type, status, totalMarks, createdAt
    //
    // Collection: results
    // Fields: studentId, studentName, examId, marksObtained, grade, remarks, updatedAt
    //
    // Collection: library_books
    // Fields: title, author, total, available, isbn, category
    //
    // Collection: library_issues
    // Fields: bookId, bookTitle, studentId, studentName, studentClass, issueDate, dueDate, returnDate, status
    //
    // Collection: staff
    // Fields: name, role, salary, joinDate, status
    //
    // Collection: payroll
    // Fields: staffId, staffName, role, month, amount, bonus, deductions, netSalary, status, paymentDate, paymentMethod
    //
    // Collection: notifications
    // Fields: recipientId, title, message, type, read, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin') || request.auth.token.email == "mk.rabbani.cse@gmail.com";
    }

    function isTeacher() {
      return hasRole('teacher');
    }

    function isParent() {
      return hasRole('parent');
    }

    function isStudent() {
      return hasRole('student');
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.role in ['admin', 'teacher', 'parent', 'student'];
    }

    function isValidSystemConfig(data) {
      return data.keys().hasAll(['schoolName', 'academicYear']) &&
             data.schoolName is string && data.schoolName.size() > 0 &&
             data.academicYear is string && data.academicYear.size() > 0 &&
             (data.get('address', '') is string) &&
             (data.get('phone', '') is string) &&
             (data.get('email', '') is string) &&
             (data.get('website', '') is string);
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'rollNumber', 'classId', 'guardianPhone', 'admissionDate', 'studentId']) &&
             data.name is string && data.name.size() > 0 &&
             data.rollNumber is string && data.rollNumber.size() > 0 &&
             data.admissionDate is string && data.admissionDate.size() > 0 &&
             data.studentId is string && data.studentId.size() > 0;
    }

    function isValidExam(data) {
      return data.keys().hasAll(['subject', 'classId', 'date', 'time', 'type', 'status', 'totalMarks']) &&
             data.totalMarks is number && data.totalMarks > 0;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['studentId', 'examId', 'marksObtained', 'grade']) &&
             data.marksObtained is number;
    }

    function isValidStaff(data) {
      return data.keys().hasAll(['name', 'role', 'salary', 'status']) &&
             data.salary is number &&
             data.status in ['active', 'inactive'];
    }

    function isValidPayroll(data) {
      return data.keys().hasAll(['staffId', 'month', 'netSalary', 'status']) &&
             data.netSalary is number &&
             data.status in ['paid', 'pending'];
    }

    function isValidRole(data) {
      return data.keys().hasAll(['name', 'permissions']) &&
             data.name is string && data.name.size() > 0;
    }

    // Rules
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role != 'admin' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /students/{studentId} {
      allow read: if isAdmin() || isTeacher() || (isParent() && resource.data.parentId == request.auth.uid) || (isStudent() && studentId == request.auth.uid);
      allow create: if (isAdmin() || isTeacher()) && isValidStudent(request.resource.data);
      allow update: if (isAdmin() || isTeacher()) && isValidStudent(request.resource.data);
      allow delete: if isAdmin() || isTeacher();
    }

    match /classes/{classId} {
      allow read: if isAdmin() || isTeacher();
      allow write: if isAdmin() || isTeacher();
    }

    match /attendance/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    match /fees/{id} {
      allow read: if isAdmin() || (isParent() && get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.parentId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /exams/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    match /results/{id} {
      allow read: if isAdmin() || isTeacher() || (isParent() && get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.parentId == request.auth.uid) || (isStudent() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin() || isTeacher();
    }

    match /library_books/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /library_issues/{id} {
      allow read: if isAdmin() || isTeacher() || isOwner(resource.data.studentId);
      allow write: if isAdmin();
    }

    match /staff/{id} {
      allow read: if isAdmin() || isTeacher();
      allow write: if isAdmin();
    }

    match /payroll/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.staffId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /notifications/{id} {
      allow read: if isOwner(resource.data.recipientId);
      allow create: if isAdmin() || isTeacher();
      allow update: if isOwner(resource.data.recipientId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    match /config/system {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidSystemConfig(request.resource.data);
    }

    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidRole(request.resource.data);
    }
  }
}
