{
  "entities": {
    "User": {
      "title": "User",
      "description": "Base user entity for authentication and role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher", "parent", "student"] },
        "photoURL": { "type": "string", "format": "uri" },
        "phone": { "type": "string" },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "email": { "type": "boolean" },
            "push": { "type": "boolean" },
            "attendance": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Detailed student profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string", "description": "Custom ID (Year + Roll Number)" },
        "imageUrl": { "type": "string", "description": "Student photo URL or Base64" },
        "name": { "type": "string" },
        "rollNumber": { "type": "string" },
        "classId": { "type": "string" },
        "parentId": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "address": { "type": "string" },
        "admissionDate": { "type": "string", "format": "date" },
        "guardianName": { "type": "string" },
        "guardianRelation": { "type": "string" },
        "guardianPhone": { "type": "string" },
        "bloodGroup": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"] },
        "status": { "type": "string", "enum": ["active", "inactive", "graduated"] }
      },
      "required": ["name", "rollNumber", "classId", "guardianPhone", "admissionDate", "guardianName", "guardianRelation"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance records.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "classId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "markedBy": { "type": "string" }
      },
      "required": ["studentId", "date", "status"]
    },
    "Fee": {
      "title": "Fee",
      "description": "Fee collection records.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["tuition", "exam", "library", "other"] },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "date": { "type": "string", "format": "date" },
        "transactionId": { "type": "string" }
      },
      "required": ["studentId", "amount", "status", "date"]
    },
    "Exam": {
      "title": "Exam",
      "description": "Exam schedules and details.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "classId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "type": { "type": "string", "enum": ["midterm", "final", "quiz", "monthly"] },
        "status": { "type": "string", "enum": ["scheduled", "completed", "ongoing"] },
        "totalMarks": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subject", "classId", "date", "time", "type", "status", "totalMarks"]
    },
    "Result": {
      "title": "Result",
      "description": "Student exam results.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "examId": { "type": "string" },
        "marksObtained": { "type": "number" },
        "grade": { "type": "string" },
        "remarks": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "examId", "marksObtained", "grade"]
    },
    "LibraryBook": {
      "title": "LibraryBook",
      "description": "Books in the school library.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "isbn": { "type": "string" },
        "category": { "type": "string" },
        "total": { "type": "number" },
        "available": { "type": "number" }
      },
      "required": ["title", "author", "total"]
    },
    "LibraryIssue": {
      "title": "LibraryIssue",
      "description": "Records of books issued to students.",
      "type": "object",
      "properties": {
        "bookId": { "type": "string" },
        "bookTitle": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "studentClass": { "type": "string" },
        "issueDate": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "returnDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["issued", "returned"] }
      },
      "required": ["bookId", "studentId", "issueDate", "dueDate", "status"]
    },
    "Payroll": {
      "title": "Payroll",
      "description": "Staff salary records.",
      "type": "object",
      "properties": {
        "staffId": { "type": "string" },
        "staffName": { "type": "string" },
        "role": { "type": "string" },
        "month": { "type": "string" },
        "amount": { "type": "number", "description": "Base salary" },
        "bonus": { "type": "number" },
        "deductions": { "type": "number" },
        "netSalary": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending"] },
        "paymentDate": { "type": "string", "format": "date" },
        "paymentMethod": { "type": "string" }
      },
      "required": ["staffId", "month", "netSalary", "status"]
    },
    "Staff": {
      "title": "Staff",
      "description": "School staff members.",
      "type": "object",
      "properties": {
        "staffId": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "department": { "type": "string" },
        "phone": { "type": "string" },
        "nid": { "type": "string" },
        "address": { "type": "string" },
        "salary": { "type": "number" },
        "joinDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["staffId", "name", "role", "salary", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System alerts and communication.",
      "type": "object",
      "properties": {
        "recipientId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["alert", "info", "update"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["recipientId", "title", "message"]
    },
    "Class": {
      "title": "Class",
      "description": "School class and section definitions.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "section": { "type": "string" },
        "teacher": { "type": "string" },
        "roomNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "section", "teacher"]
    },
    "SystemConfig": {
      "title": "SystemConfig",
      "description": "Global school settings and configurations.",
      "type": "object",
      "properties": {
        "schoolName": { "type": "string" },
        "academicYear": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "website": { "type": "string" },
        "schoolLogoUrl": { "type": "string", "description": "Base64 or URL of the school logo" },
        "lastBackup": { "type": "string", "format": "date-time" }
      },
      "required": ["schoolName", "academicYear"]
    },
    "Role": {
      "title": "Role",
      "description": "Staff role definitions and their granular permissions.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "permissions": {
          "type": "object",
          "properties": {
            "students": { "type": "string", "enum": ["none", "view", "full"] },
            "attendance": { "type": "string", "enum": ["none", "view", "full"] },
            "fees": { "type": "string", "enum": ["none", "view", "full"] },
            "exams": { "type": "string", "enum": ["none", "view", "full"] },
            "library": { "type": "string", "enum": ["none", "view", "full"] },
            "staff": { "type": "string", "enum": ["none", "view", "full"] },
            "payroll": { "type": "string", "enum": ["none", "view", "full"] },
            "settings": { "type": "string", "enum": ["none", "view", "full"] }
          }
        },
        "isSystem": { "type": "boolean", "description": "Whether this is a protected system role" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "permissions"]
    },
    "Routine": {
      "title": "Routine",
      "description": "Class routine / weekly schedule.",
      "type": "object",
      "properties": {
        "day": { "type": "string", "enum": ["Saturday", "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday"] },
        "className": { "type": "string" },
        "subject": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "teacher": { "type": "string" }
      },
      "required": ["day", "className", "subject", "startTime", "endTime"]
    },
    "Subject": {
      "title": "Subject",
      "description": "School subjects.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" }
      },
      "required": ["name"]
    },
    "StaffAttendance": {
      "title": "StaffAttendance",
      "description": "Daily attendance records for school staff.",
      "type": "object",
      "properties": {
        "staffId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["staffId", "date", "status"]
    }
  },
  "firestore": {
    "/subjects/{subjectId}": { "schema": "Subject", "description": "Subject definitions" },
    "/routine/{routineId}": { "schema": "Routine", "description": "Class routines" },
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/config/system": { "schema": "SystemConfig", "description": "Global settings" },
    "/students/{studentId}": { "schema": "Student", "description": "Student records" },
    "/classes/{classId}": { "schema": "Class", "description": "Class definitions" },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "Daily attendance" },
    "/staff_attendance/{attendanceId}": { "schema": "StaffAttendance", "description": "Staff attendance" },
    "/fees/{feeId}": { "schema": "Fee", "description": "Fee payments" },
    "/exams/{examId}": { "schema": "Exam", "description": "Exam schedules" },
    "/results/{resultId}": { "schema": "Result", "description": "Exam results" },
    "/library_books/{bookId}": { "schema": "LibraryBook", "description": "Library inventory" },
    "/library_issues/{issueId}": { "schema": "LibraryIssue", "description": "Book issue records" },
    "/staff/{staffId}": { "schema": "Staff", "description": "Staff records" },
    "/payroll/{payrollId}": { "schema": "Payroll", "description": "Staff payroll" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/roles/{roleId}": { "schema": "Role", "description": "Staff role definitions" }
  }
}
